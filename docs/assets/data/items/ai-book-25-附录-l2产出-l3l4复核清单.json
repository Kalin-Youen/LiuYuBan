{"id":"ai-book-25-附录-l2产出-l3l4复核清单","html":"<h1 id=\"l3l4-复核清单\">L3/L4 复核清单</h1>\n<blockquote>\n<p>用途：L3/L4 模型或作者对本轮 L2 全部产出做逐项复核\n产出范围：附录_L2产出_*.md（共 11 个文件）\n复核日期：<strong><em>_年</em></strong>_月<strong><em>_日\n复核模型/人员：</em></strong>___</p>\n</blockquote>\n<hr>\n<h2 id=\"一全局性裁定需-l4\">一、全局性裁定（需 L4）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>裁定项</th>\n<th>选项</th>\n<th>裁定结果</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>G1</td>\n<td>P0 任务范围</td>\n<td>A) 路线图§16：3个（方法卡+审查表+案例） B) 路线图§8：5个（+提示词+模板） C) 其他</td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>G2</td>\n<td>全部产出回写位置</td>\n<td>A) AI协作卷附录 B) 拓展卷方法卡章节 C) 站点工具包入口 D) 单独目录 E) 混合（按类型分）</td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>G3</td>\n<td>正式术语表规模</td>\n<td>A) 核心15-20个 B) 全部37个 C) 其他</td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>G4</td>\n<td>案例素材来源</td>\n<td>A) 作者提供 B) 从评论提取 C) 用户提交 D) L2模拟（标注为模拟）</td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>G5</td>\n<td>B3 评论数据来源</td>\n<td>A) 站点API B) 作者导出 C) 暂不执行</td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>G6</td>\n<td>外部反馈信是否回写</td>\n<td>A) 回写到第10章示例 B) 单独保留 C) 不回写</td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"二a1-方法卡复核需-l3-深度复核\">二、A1 方法卡复核（需 L3 深度复核）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>检查项</th>\n<th>通过</th>\n<th>小修</th>\n<th>退回</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>A1-1</td>\n<td>10张卡是否覆盖专题核心方法</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A1-2</td>\n<td>每张卡能否单独使用</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A1-3</td>\n<td>每张卡有明确动作</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A1-4</td>\n<td>没有把\"差异\"直接写成\"可用落差\"</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A1-5</td>\n<td>保留边界、耦合、路径、反馈、失败条件</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A1-6</td>\n<td>没有发明原文没有的宏大结论</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A1-7</td>\n<td>是否需要增加\"强度等级\"字段</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A1-8</td>\n<td>卡片5和6是否合并</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A1-9</td>\n<td>六种误判是否单独出卡</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A1-10</td>\n<td>是否需要从第六节/第十四节补卡</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<p>逐卡复核：</p>\n<table>\n<thead>\n<tr>\n<th>卡片</th>\n<th>忠于原文</th>\n<th>未越权</th>\n<th>动作可用</th>\n<th>风险提示充分</th>\n<th>处理</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>1 四词拆开法</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>2 可用落差判据式</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>3 总量≠可用量</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>4 落差来源五分法</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>5 问题化判断法</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>6 学习链诊断法</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>7 耗散三分类</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>8 结构沉淀五条件</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>9 吸收系数检查</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>10 差异可用十问</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"三a2-审查表复核需-l3-深度复核\">三、A2 审查表复核（需 L3 深度复核）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>检查项</th>\n<th>通过</th>\n<th>小修</th>\n<th>退回</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>A2-1</td>\n<td>用户能直接复制使用</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A2-2</td>\n<td>字段不超过12个</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A2-3</td>\n<td>能区分事实、推断、类比、建议</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A2-4</td>\n<td>必须包含失败条件和下一步验证</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A2-5</td>\n<td>不写成抽象文章</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A2-6</td>\n<td>快速版是否保留</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A2-7</td>\n<td>空白模板是否保留</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A2-8</td>\n<td>\"失败条件\"空白处理是否补充说明</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A2-9</td>\n<td>是否增加\"强度等级\"字段</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>A2-10</td>\n<td>是否需要多轮对话审查指引</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"四p0-04-提示词复核需-l3-抽样复核\">四、P0-04 提示词复核（需 L3 抽样复核）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>检查项</th>\n<th>通过</th>\n<th>小修</th>\n<th>退回</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>P04-1</td>\n<td>每个提示词可独立使用</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>P04-2</td>\n<td>有明确输出要求</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>P04-3</td>\n<td>提示词5与A2审查表关系：合并/并存</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>P04-4</td>\n<td>是否增加\"适用模型等级\"标注</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"五p0-05-模板复核需-l3-深度复核\">五、P0-05 模板复核（需 L3 深度复核）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>检查项</th>\n<th>通过</th>\n<th>小修</th>\n<th>退回</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>P05-1</td>\n<td>用户能直接复制</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>P05-2</td>\n<td>字段完整</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>P05-3</td>\n<td>有填写说明</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>P05-4</td>\n<td>差异判断表与卡片10关系：合并/区分</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>P05-5</td>\n<td>是否需要轻量版（3-5字段）</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"六b1-过强句子复核需-l3-逐条复核\">六、B1 过强句子复核（需 L3 逐条复核）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>原句摘要</th>\n<th>确实过强</th>\n<th>上下文中合理</th>\n<th>需降强</th>\n<th>需删除</th>\n<th>处理</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>B1-1</td>\n<td>\"问题的本质\"</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B1-2</td>\n<td>\"必然要行动；行动必然消耗资源\"</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B1-3</td>\n<td>\"证明了\"</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B1-4</td>\n<td>三个\"所有\"排比</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B1-5</td>\n<td>\"解释一切\"</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B1-6</td>\n<td>\"不会统一\"</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B1-7</td>\n<td>\"不是所有博弈\"</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B1-8</td>\n<td>\"完全排除大众\"</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<p>B1 扩展裁定：</p>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>裁定项</th>\n<th>是</th>\n<th>否</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>B1-E1</td>\n<td>是否扩大扫描范围到主书稿和白话卷</td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B1-E2</td>\n<td>是否增加隐性信号词做第二轮扫描</td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"七b2-协作规则复核需-l3-抽样复核\">七、B2 协作规则复核（需 L3 抽样复核）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>检查项</th>\n<th>通过</th>\n<th>小修</th>\n<th>退回</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>B2-1</td>\n<td>18条规则是否过多，目标条数</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B2-2</td>\n<td>R1和R7是否合并</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B2-3</td>\n<td>是否需要\"规则冲突处理\"条目</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>B2-4</td>\n<td>是否标注\"L2只读\"规则</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"八c1-导读复核需-l3-抽样复核\">八、C1 导读复核（需 L3 抽样复核）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>检查项</th>\n<th>通过</th>\n<th>小修</th>\n<th>退回</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>C1-1</td>\n<td>不新增原文没有的观点</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>C1-2</td>\n<td>功能分类（补桥/压实/展开/自审）是否准确</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>C1-3</td>\n<td>可独立阅读</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"九c2-术语复核需-l3-深度复核\">九、C2 术语复核（需 L3 深度复核）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>检查项</th>\n<th>通过</th>\n<th>小修</th>\n<th>退回</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>C2-1</td>\n<td>术语定义是否忠于原文</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>C2-2</td>\n<td>强度等级判断是否准确</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>C2-3</td>\n<td>\"流/流动\"是否应降为工作假说</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>C2-4</td>\n<td>\"锚点包\"\"版本快照\"是否进入术语表</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>C2-5</td>\n<td>术语间依赖关系是否需标注</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"十p1-01-案例库复核需-l3-抽样复核\">十、P1-01 案例库复核（需 L3 抽样复核）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>检查项</th>\n<th>通过</th>\n<th>小修</th>\n<th>退回</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>P101-1</td>\n<td>模板字段是否过多</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>P101-2</td>\n<td>失败类型分类是否完整</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>P101-3</td>\n<td>是否需要轻量版</td>\n<td></td>\n<td></td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"十一外部反馈信处理需-l4\">十一、外部反馈信处理（需 L4）</h2>\n<table>\n<thead>\n<tr>\n<th>#</th>\n<th>裁定项</th>\n<th>选项</th>\n<th>裁定结果</th>\n<th>备注</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>F1</td>\n<td>反馈信是否回写到第10章示例</td>\n<td>A)是 B)单独保留 C)不回写</td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>F2</td>\n<td>反馈中\"三个方向\"是否作为外部验证信号</td>\n<td>A)是 B)否 C)待观察</td>\n<td></td>\n<td></td>\n</tr>\n<tr>\n<td>F3</td>\n<td>\"少一点宏大宣言\"是否触发B1扩大扫描</td>\n<td>A)是 B)否</td>\n<td></td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<hr>\n<h2 id=\"复核结果汇总\">复核结果汇总</h2>\n<table>\n<thead>\n<tr>\n<th>产出</th>\n<th>处理结果</th>\n<th>修改要点</th>\n<th>是否可回写</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>A1 方法卡</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n<tr>\n<td>A2 审查表</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n<tr>\n<td>A3 任务清单</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n<tr>\n<td>P0-04 提示词</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n<tr>\n<td>P0-05 模板</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n<tr>\n<td>B1 过强扫描</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n<tr>\n<td>B2 协作规则</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n<tr>\n<td>P1-01 案例库</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n<tr>\n<td>C1 导读</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n<tr>\n<td>C2 术语候选</td>\n<td>□通过 □小修 □退回 □升级</td>\n<td></td>\n<td>□是 □候选 □否</td>\n</tr>\n</tbody>\n</table>\n<p>复核人签名：<strong><em>_</em>_  日期：</strong>____</p>"}